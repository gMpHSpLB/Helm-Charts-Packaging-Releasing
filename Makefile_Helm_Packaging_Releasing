	helm list -n $(NS_DEV)

.PHONY: helm-show-status-dev-release-in-namespace
helm-show-status-dev-release-in-namespace: ## Show dev release status in namespace
	helm status $(RELEASE_DEV) -n $(NS_DEV)

.PHONY: helm-run-tests-for-dev-release-in-namespace
helm-run-tests-for-dev-release-in-namespace: ## Run helm tests for dev release in namespace
	helm test $(RELEASE_DEV) -n $(NS_DEV) --logs

