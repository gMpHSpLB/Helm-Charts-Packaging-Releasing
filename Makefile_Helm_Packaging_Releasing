# Exercise 01: Scaffold and Lint
## Objective :
###Create a fresh Helm chart and validate that it is structurally correct.
### Note: If you have already added Charts.yaml and templetes and other files manuulay then you keep helm-scaffold-new-chart, treat it as a demo target, 
#         but don’t run it on top of the chart you’ve already built.
.PHONY: helm-scaffold-new-chart
helm-scaffold-new-chart: print_scaffold_lint_render_purpose ## Scaffold a new chart (only if it does not already exist)
	@if [ -d "$(CHART_DIR)" ]; then \
	  	echo "Chart directory $(CHART_DIR) already exists. Skipping 'helm create' to avoid overwriting custom Chart.yaml and templates."; \
	else \
		echo "Chart directory $(CHART_DIR) not found. Creating new chart skeleton with 'helm create'..."; \
		helm create $(CHART_DIR); \
	fi

.PHONY: helm-lint-validate-chart
helm-lint-validate-chart: ## Validate chart
	@echo "==> Validate chart syntax and conventions."
	helm lint $(CHART_DIR)

.PHONY: helm-template-dev
helm-template-dev: ## Render dev manifests
	#echo "Renders Kubernetes manifests for dev"
	helm template $(RELEASE_DEV) $(CHART_DIR) -f $(CHART_DIR)/values.yaml -f $(DEV_VALUES) -n $(NS_DEV)

