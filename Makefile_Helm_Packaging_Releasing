# Exercise 06: Diff and Rollback
## Objective
### Preview a release change before applying it and recover from a bad upgrade.
## Expected outcome
# 	- Diff shows what will change.
# 	- Upgrade applies a new revision.
# 	- Rollback restores a previous revision.
# 	- History confirms the revision sequence.
.PHONY : print_diff_and_rollback_purpose
print_diff_and_rollback_purpose: 
	@printf '$(GREEN) %s $(RESET) \n\n' \
		'===========================================================================================' \
		' 				Diff and Rollback								   ' \
		'===========================================================================================' \
		' Purpose: '\
		'  - Show diff for dev release before applying changes.'\
		'   - Apply a new dev release revision.'\
		'   - Roll back to a previous revision.'

# This:
# 	Keeps your existing base and dev values.
# 	Shows a diff from current state (nodePort 30082, replicaCount 1, no annotation) to new values (nodePort 30083, replicas 2, annotation dev-v2).
# 	Requires the helm-diff plugin, which you’re already using
.PHONY: helm-diff-dev-release-change-before-apply-in-namespace
helm-diff-dev-release-change-before-apply-in-namespace: print_diff_and_rollback_purpose ## Diff dev release changes before upgrade/apply
	@echo "==> Diff dev release changes before upgrade/apply"
	helm diff upgrade $(RELEASE_DEV) $(CHART_DIR) \
	  -f $(CHART_DIR)/values.yaml -f $(DEV_VALUES) \
	  --set service.nodePort=30083 \
	  --set replicaCount=2 \
	  --set podAnnotations."app\.kubernetes\.io/environment"="dev-v2" \
	  -n $(NS_DEV)

.PHONY: helm-upgrade-install-dev-release-in-namespace_1
helm-upgrade-install-dev-release-in-namespace_1: print_release_management_purpose ## Install or upgrade dev release in namespace
	@echo "==> Checking dev release - Does it exist? if yes then upgrade it."
	@if helm status $(RELEASE_DEV) -n $(NS_DEV) >/dev/null 2>&1; then \
		echo "==> Upgrading existing dev release: $(RELEASE_DEV) namespace: $(NS_DEV)"; \
		helm upgrade $(RELEASE_DEV) $(CHART_DIR) \
		  -f $(CHART_DIR)/values.yaml -f $(DEV_VALUES) \
		  --set service.nodePort=30083 \
		  --set replicaCount=2 \
		  --set podAnnotations."app\.kubernetes\.io/environment"="dev-v2" \
		  -n $(NS_DEV); \
	else \
		echo "==> Installing new dev release: $(RELEASE_DEV) namespace: $(NS_DEV)"; \
		helm install $(RELEASE_DEV) $(CHART_DIR) \
		  -f $(CHART_DIR)/values.yaml -f $(DEV_VALUES) \
		  --set service.nodePort=30083 \
		  --set replicaCount=2 \
		  --set podAnnotations."app\.kubernetes\.io/environment"="dev-v2" \
		  -n $(NS_DEV) --create-namespace; \
	fi

