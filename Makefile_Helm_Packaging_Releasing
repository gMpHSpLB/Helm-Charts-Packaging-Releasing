		'   - Inspect Helm environment variables and paths.'\
		'   - List dev releases.'\
		'   - Show dev release status.'

.PHONY: helm-list-dev-releases-in-namespace
helm-list-dev-releases-in-namespace: ## List releases in dev namespace.
	@echo "==> List releases in dev namespace."
	helm list -n $(NS_DEV)

.PHONY: helm-show-status-dev-release-in-namespace
helm-show-status-dev-release-in-namespace: ## Show dev release status in namespace
	helm status $(RELEASE_DEV) -n $(NS_DEV)

.PHONY: helm-show-env-variables
helm-show-env-variables: ## Show Helm environment variables
	@echo "==> Show Helm environment variables"
	helm env