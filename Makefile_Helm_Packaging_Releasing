.PHONY: ghcr-check-secrets
ghcr-check-secrets: 
	@if [ -z "$(GHCR_USERNAME)" ] || [ -z "$(GHCR_PAT)" ]; then \
	  echo "GHCR_USERNAME and GHCR_PAT must be set in .secrets"; \
	  exit 1; \
	fi

.PHONY: helm-oci-registry-login
helm-oci-registry-login: print_registry_roundtrip_purpose ghcr-check-secrets ## Login to GitHub Container Registry (GHCR, OCI) 
	@if [ -z "$(GHCR_USERNAME)" ] || [ -z "$(GHCR_PAT)" ]; then \
	  echo "GHCR_USERNAME and GHCR_PAT must be set in the environment"; \
	else \
	echo "==> Login to OCI registry"; \
		helm registry login $(GHCR_HOST) \
		--username "$(GHCR_USERNAME)" \
		--password "$(GHCR_PAT)"; \
	fi
	
.PHONY: helm-push-chart-packag-to-registry
helm-push-chart-packag-to-registry: helm-oci-registry-login ghcr-check-secrets ## Push packaged chart to GHCR (OCI)
	@if [ ! -f "$(DIST_DIR)/$(CHART_PKG)" ]; then \
	  echo "Chart package $(DIST_DIR)/$(CHART_PKG) not found. Run 'make package' first."; \
	else \
	  echo "==> Push packaged chart to registry."; \
		helm push "$(DIST_DIR)/$(CHART_PKG)" \
		oci://$(GHCR_HOST)/$(GHCR_USERNAME_LOWERCASE)/$(GHCR_REPO); \
	fi
	
.PHONY: helm-pull-chart-by-version-from-registry
helm-pull-chart-by-version-from-registry: helm-oci-registry-login ghcr-check-secrets ## Pull chart from GHCR (OCI)
	@echo "==> Pull chart by version from registry"
	mkdir -p $(DOWNLOAD_DIR)
	helm pull oci://$(GHCR_HOST)/$(GHCR_USERNAME_LOWERCASE)/$(GHCR_REPO)/$(HELM_CHART_NAME) \
	  --version $(CHART_VERSION) \
	  --destination $(DOWNLOAD_DIR)

.PHONY: helm-add-a-repo
helm-add-a-repo: ## Add chart repo
	@echo "==> Add a Helm repository."
	helm repo add $(PROJECT)-repo https://example.com/charts

.PHONY: helm-repo-update
helm-repo-update: ## Update repo cache
	@echo "==> Refresh/Update repository cache."
	helm repo update

.PHONY: helm-search-repo
helm-search-repo: ## Search chart repo
	@echo "==> Search chart repositories."
	helm search repo $(PROJECT)

