# Exercise 05: Release Management
## Objective
### Install or upgrade the same chart across multiple namespaces and environments.
## Expected outcome
# 	- Releases exist in their respective namespaces.
# 	- History shows revisions.
# 	- Manifest and values reflect what is deployed.
.PHONY : print_release_management_purpose
print_release_management_purpose: 
	@printf '$(GREEN) %s $(RESET) \n\n' \
		'===========================================================================================' \
		' 				Release Management (dev/staging/prod)				     				    ' \
		'	- It deploys the chart into Kubernetes namespaces for dev, staging, and prod.           ' \
		'   - This script assumes the chart is already available locally in charts/catalog-service  ' \
		'===========================================================================================' \
		' Purpose:' \
		'   - Install or upgrade dev, staging, and prod releases.' \
		'   - Inspect dev release history, manifest, and values.' \
		'	- Verify deployments in each environment via kubectl.'

.PHONY: helm-reset-dev-release
helm-reset-dev-release: ## Delete dev release and dev namespace for a clean reinstall
	@echo "==> Uninstall dev release"
	-helm uninstall $(RELEASE_DEV) -n $(NS_DEV) --wait --timeout 5m || true
	@echo "==> Delete dev namespace"
	-kubectl delete namespace $(NS_DEV) --ignore-not-found=true || true
	@echo "==> Dev environment cleaned up"

.PHONY: helm-reset-dev-release-to-baseline
helm-reset-dev-release-to-baseline: ## Uninstall dev release and reinstall baseline
	@echo "==> Reset dev release to baseline (uninstall + reinstall)"
	helm uninstall $(RELEASE_DEV) -n $(NS_DEV) --wait --timeout 5m || true
	kubectl get ns $(NS_DEV) >/dev/null 2>&1 || kubectl create ns $(NS_DEV)
	helm install $(RELEASE_DEV) $(CHART_DIR) \
	  -f $(CHART_DIR)/values.yaml \
	  -f $(DEV_VALUES) \
	  -n $(NS_DEV)

.PHONY: helm-reset-staging-release
helm-reset-staging-release: ## Delete staging release and staging namespace for a clean reinstall
	@echo "==> Uninstall staging release"
	-helm uninstall $(RELEASE_STAGING) -n $(NS_STAGING) || true
	@echo "==> Delete staging namespace"
	-kubectl delete namespace $(NS_STAGING) --ignore-not-found=true || true
	@echo "==> Staging environment cleaned up"

.PHONY: helm-reset-prod-release
helm-reset-prod-release: ## Delete prod release and prod namespace for a clean reinstall
	@echo "==> Uninstall prod release"
	-helm uninstall $(RELEASE_PROD) -n $(NS_PROD) || true
	@echo "==> Delete prod namespace"
	-kubectl delete namespace $(NS_PROD) --ignore-not-found=true || true
	@echo "==> Prod environment cleaned up"

.PHONY: helm-upgrade-install-dev-release-in-namespace
helm-upgrade-install-dev-release-in-namespace: ## Install or upgrade dev release in namespace
	@echo "==> Checking dev release - Does it exists? if yes then upgrade it."
	@if helm status $(RELEASE_DEV) -n $(NS_DEV) >/dev/null 2>&1; then \
		echo "==> Upgrading existing dev release: $(RELEASE_DEV) namespace: $(NS_DEV)"; \
		helm upgrade $(RELEASE_DEV) $(CHART_DIR) -f $(CHART_DIR)/values.yaml -f $(DEV_VALUES) -n $(NS_DEV); \
	else \
		echo "==> Installing new dev release: $(RELEASE_DEV) namespace: $(NS_DEV)"; \
		helm install $(RELEASE_DEV) $(CHART_DIR) -f $(CHART_DIR)/values.yaml -f $(DEV_VALUES) -n $(NS_DEV) --create-namespace; \
	fi


.PHONY: helm-upgrade-install-staging-in-namespace
helm-upgrade-install-staging-release-in-namespace: ## Install or upgrade staging release in-namespace
	@echo "==> Checking staging release"
	@if helm status $(RELEASE_STAGING) -n $(NS_STAGING) >/dev/null 2>&1; then \
		echo "==> Upgrading existing staging release: $(RELEASE_STAGING) namespace: $(NS_STAGING)"; \
		helm upgrade $(RELEASE_STAGING) $(CHART_DIR) -f $(CHART_DIR)/values.yaml -f $(STAGING_VALUES) -n $(NS_STAGING); \
	else \
		echo "==> Installing new staging release: $(RELEASE_STAGING) namespace: $(NS_STAGING)"; \
		helm install $(RELEASE_STAGING) $(CHART_DIR) -f $(CHART_DIR)/values.yaml -f $(STAGING_VALUES) -n $(NS_STAGING) --create-namespace; \
	fi

.PHONY: helm-upgrade-install-prod-in-namespace
helm-upgrade-install-prod-release-in-namespace: ## Install or upgrade prod release in-namespace
	@echo "==> Checking prod release"
	@if helm status $(RELEASE_PROD) -n $(NS_PROD) >/dev/null 2>&1; then \
		echo "==> Upgrading existing prod release: $(RELEASE_PROD) namespace: $(NS_PROD)"; \
		helm upgrade $(RELEASE_PROD) $(CHART_DIR) -f $(CHART_DIR)/values.yaml -f $(PROD_VALUES) -n $(NS_PROD); \
	else \
		echo "==> Installing new prod release: $(RELEASE_PROD) namespace: $(NS_PROD)"; \
		helm install $(RELEASE_PROD) $(CHART_DIR) -f $(CHART_DIR)/values.yaml -f $(PROD_VALUES) -n $(NS_PROD) --create-namespace; \
