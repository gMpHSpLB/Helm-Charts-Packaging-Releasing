# Use Bash for shell commands in recipes.
# This gives us better shell features than plain sh.
SHELL := /bin/bash

# Default target
.DEFAULT_GOAL := help
.PHONY: help
# Self-documenting help: list targets with "##" comments
help: ## Show all available targets with short descriptions.
	# This target reads the Makefile and prints any line ending with ##.
	# Use this when you want to discover available commands quickly.
	# Expected output: a list of targets and one-line descriptions.
	@awk 'BEGIN {FS = ":.*##"; printf "\nUsage:\n  make <target>\n\nTargets:\n"} /^[a-zA-Z0-9_.-]+:.*##/ { printf "  %-28s --> %s\n", $$1, $$2 }' $(MAKEFILE_LIST)

.PHONY: 

# ------------------------------------------------------------------------------------------------------------------
# ---------- GLOBAL CONFIG -----------------------------------------------------------------------------------------
# Load secrets from .secrets if present
# What this does:
# 	- If .secrets exists, include it so GHCR_USERNAME and GHCR_PAT become Make variables.
# 	- export the variable names parsed from the file so they are available to shell commands run by Make.
SECRETS_FILE ?= .secrets

ifneq ("$(wildcard $(SECRETS_FILE))","")
include $(SECRETS_FILE)
export $(shell sed -n 's/^\([A-Za-z_][A-Za-z0-9_]*\)=.*/\1/p' $(SECRETS_FILE))
endif

PROJECT 				?= catalog-service
CHART_DIR 				?= charts/$(PROJECT)
DIST_DIR 				?= dist
DOWNLOAD_DIR 			?= downloads

# GitHub Container Registry
GHCR_HOST 				?= ghcr.io
GHCR_REPO 				?= helm-lab
GHCR_USERNAME_RAW			?= gMpHSpLB
GHCR_USERNAME_LOWERCASE		:= $(shell printf '%s' '$(GHCR_USERNAME_RAW)' | tr '[:upper:]' '[:lower:]')
# REGISTRY_HOST 			?= registry.example.com
# REGISTRY_PATH 			?= helm-lab
# Chart SemVer:
# - patch: template fixes, metadata updates, small config changes
# - minor: new optional chart features or new values
# - major: breaking schema or resource behavior changes
CHART_VERSION 			?= 0.1.0

# Application image version
APP_VERSION   			?= 1.0.0

HELM_CHART_NAME 		?= myapp-helm-chart
CHART_PKG 				?= $(HELM_CHART_NAME)-$(CHART_VERSION).tgz

RELEASE_DEV 			?= $(PROJECT)-dev
RELEASE_STAGING 		?= $(PROJECT)-staging
RELEASE_PROD 			?= $(PROJECT)-prod

NS_DEV 					?= catalog-dev
NS_STAGING 				?= catalog-staging
NS_PROD 				?= catalog-prod

DEV_VALUES 				?= environments/dev.yaml
STAGING_VALUES 			?= environments/staging.yaml
PROD_VALUES 			?= environments/prod.yaml

RED    := \033[1;31m
YELLOW := \033[1;33m
GREEN  :="\033[1;32m"
CYAN   := \033[1;36m
RESET  := \033[0m
